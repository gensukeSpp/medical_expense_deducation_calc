{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Receipt structured data",
  "type": "object",
  "properties": {
    "name": {"type": ["string", "null"], "description": "Receipt recipient name"},
    "clinic": {"type": ["string", "null"], "description": "Clinic or pharmacy name"},
    "amount": {"type": ["number", "null"], "description": "Paid amount in JPY"},
    "date": {"type": ["string", "null"], "format": "date", "description": "ISO date YYYY-MM-DD"}
  },
  "required": ["amount"],
  "additionalProperties": false
}
